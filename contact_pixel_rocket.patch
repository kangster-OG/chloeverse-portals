+        const local = flyT - idx * DUR.perPlanet;
+        if (flyT < flyTotal) {
+          const p = PLANETS[clamp(idx, 0, PLANETS.length - 1)];
+          const prog = smooth(local / DUR.perPlanet);
+          const planetX = lerp(W + 60, -60, prog);
+          drawPlanet(ctx, p, planetX, 92, t);
+          const isPluto = p.name === "Pluto";
+          drawRocket(ctx, 110, 78, t, isPluto && local > 0.55 ? "wobble" : "fly");
+          txt(ctx, p.name.toUpperCase() + "!", 160, 18, "#ffffff", 12, "center");
+          if (isPluto) txt(ctx, "uh oh!", 245, 46, "#ffd36b", 10, "center");
