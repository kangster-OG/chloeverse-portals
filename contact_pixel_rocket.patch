+      await navigator.clipboard.writeText(v);
+      setCopied("Copied!");
+    } catch {
+      setCopied("Copy failed");
+    }
+    window.setTimeout(() => setCopied(null), 900);
+  };
+
+  const DUR = useMemo(() => ({ countdown: 1.5, liftoff: 1.1, atmo: 0.9, perPlanet: 1.0, crash: 0.35, boom: 0.95, card: 0.55 }), []);
+  const flyStart = DUR.countdown + DUR.liftoff + DUR.atmo;
+  const flyTotal = PLANETS.length * DUR.perPlanet;
+  const total = flyStart + flyTotal + DUR.crash + DUR.boom + DUR.card + 0.2;
+
+  useEffect(() => {
+    const c = canvasRef.current;
+    if (!c) return;
+    c.width = W;
+    c.height = H;
+    const ctx = c.getContext("2d", { alpha: false });
+    if (!ctx) return;
