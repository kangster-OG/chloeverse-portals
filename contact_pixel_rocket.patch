+"use client";
+
+import React, { useEffect, useMemo, useRef, useState } from "react";
+
+type Channel = {
+  key: string;
+  label: string;
+  value: string;
+  href: string;
+  copyValue: string;
+};
+
+type Planet = {
+  name: string;
+  r: number;
+  base: string;
+  shade: string;
+  hi: string;
+  ring?: boolean;
+};
+
+function clamp(n: number, a: number, b: number) {
+  return Math.max(a, Math.min(b, n));
+}
+function lerp(a: number, b: number, t: number) {
+  return a + (b - a) * t;
+}
+function smooth(t: number) {
+  const x = clamp(t, 0, 1);
+  return x * x * (3 - 2 * x);
+}
+
+function px(ctx: CanvasRenderingContext2D, x: number, y: number, w: number, h: number, c: string) {
+  ctx.fillStyle = c;
+  ctx.fillRect(Math.round(x), Math.round(y), Math.round(w), Math.round(h));
+}
+function txt(ctx: CanvasRenderingContext2D, s: string, x: number, y: number, c: string, size: number, align: CanvasTextAlign) {
+  ctx.fillStyle = c;
+  ctx.font = `${size}px ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace`;
+  ctx.textAlign = align;
+  ctx.textBaseline = "top";
+  ctx.fillText(s, Math.round(x), Math.round(y));
+}
+
+function drawRocket(ctx: CanvasRenderingContext2D, x: number, y: number, t: number, mode: "pad" | "fly" | "wobble") {
+  const bob = mode === "pad" ? 0 : Math.sin(t * 6) * 1.5;
+  const wob = mode === "wobble" ? Math.sin(t * 18) * 2 : 0;
+  const xx = x + wob;
+  const yy = y + bob;
+
+  px(ctx, xx + 8, yy + 2, 8, 22, "#f7f7ff");
+  px(ctx, xx + 9, yy + 3, 6, 20, "#e6e6ff");
+  px(ctx, xx + 9, yy, 6, 3, "#ff4d7d");
+  px(ctx, xx + 10, yy + 1, 4, 2, "#ff7da1");
+  px(ctx, xx + 10, yy + 8, 4, 4, "#2bd6ff");
+  px(ctx, xx + 11, yy + 9, 2, 2, "#a6f3ff");
+  px(ctx, xx + 8, yy + 14, 8, 3, "#ff4d7d");
+  px(ctx, xx + 8, yy + 17, 8, 1, "#ffd36b");
+  px(ctx, xx + 6, yy + 18, 2, 6, "#ff4d7d");
+  px(ctx, xx + 16, yy + 18, 2, 6, "#ff4d7d");
+  px(ctx, xx + 6, yy + 20, 2, 4, "#ff7da1");
+  px(ctx, xx + 16, yy + 20, 2, 4, "#ff7da1");
+  px(ctx, xx + 9, yy + 24, 6, 3, "#3a3a48");
+  px(ctx, xx + 10, yy + 25, 4, 2, "#252530");
+
+  if (mode !== "pad") {
+    const flick = Math.floor((t * 18) % 3);
+    const h = 6 + flick;
+    px(ctx, xx + 11, yy + 27, 2, h, "#ffd36b");
+    px(ctx, xx + 11, yy + 28, 2, h - 2, "#ff7a3d");
+    if (flick === 2) px(ctx, xx + 11, yy + 29, 2, h - 3, "#fff6c7");
+  }
+}
+
+function drawPlanet(ctx: CanvasRenderingContext2D, p: Planet, cx: number, cy: number, t: number) {
+  const r = p.r;
+  for (let yy = -r; yy <= r; yy++) {
+    const w = Math.floor(Math.sqrt(Math.max(0, r * r - yy * yy)));
+    const y = cy + yy;
+    const shade = (yy / r) * 0.5 + 0.5;
+    let col = p.base;
+    if (shade > 0.62) col = p.hi;
+    else if (shade < 0.38) col = p.shade;
+    ctx.fillStyle = col;
+    ctx.fillRect(Math.round(cx - w), Math.round(y), Math.round(w * 2), 1);
+    if ((p.name === "Jupiter" || p.name === "Saturn") && Math.abs(yy) % 4 === 0) {
+      ctx.fillStyle = "rgba(0,0,0,0.10)";
+      ctx.fillRect(Math.round(cx - w), Math.round(y), Math.round(w * 2), 1);
+    }
+  }
+  ctx.fillStyle = "rgba(255,255,255,0.25)";
+  ctx.fillRect(Math.round(cx - r * 0.35), Math.round(cy - r * 0.35), 3, 3);
+  if (p.ring) {
+    const wob = Math.sin(t * 2) * 1;
+    ctx.fillStyle = "rgba(255,255,255,0.35)";
+    ctx.fillRect(Math.round(cx - r * 1.35), Math.round(cy + wob), Math.round(r * 2.7), 2);
+    ctx.fillStyle = "rgba(0,0,0,0.15)";
+    ctx.fillRect(Math.round(cx - r * 1.35), Math.round(cy + wob + 1), Math.round(r * 2.7), 1);
+  }
+}
+
+function drawExplosion(ctx: CanvasRenderingContext2D, cx: number, cy: number, t: number) {
+  const k = smooth(t);
+  const r = 8 + k * 52;
+  ctx.fillStyle = "rgba(255,246,199,0.7)";
+  ctx.beginPath();
+  ctx.arc(cx, cy, 6 + k * 22, 0, Math.PI * 2);
+  ctx.fill();
+  for (let i = 0; i < 22; i++) {
+    const a = (i / 22) * Math.PI * 2 + t * 1.4;
+    const rr = r * (0.6 + 0.5 * Math.sin(i * 1.6 + t * 3));
+    const x = cx + Math.cos(a) * rr;
+    const y = cy + Math.sin(a) * rr;
+    const sz = 2 + (i % 2);
+    px(ctx, x, y, sz, sz, i % 3 === 0 ? "#ff4d7d" : "#ffd36b");
+  }
+}
