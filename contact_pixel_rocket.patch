+        }
+      `}</style>
+
+      <canvas ref={canvasRef} className="pixel" aria-label="Pixel rocket contact animation" />
+
+      <div className="pointer-events-none absolute inset-x-0 top-0 z-20 flex items-center justify-between px-4 py-3">
