+      { name: "Venus", r: 22, base: "#f6d07a", shade: "#d2a954", hi: "#ffe7b0" },
+      { name: "Earth", r: 24, base: "#2a7bff", shade: "#1b4eb6", hi: "#76c8ff" },
+      { name: "Mars", r: 22, base: "#d05b3a", shade: "#9b3a24", hi: "#ff9a6d" },
+      { name: "Jupiter", r: 30, base: "#f2b98a", shade: "#c88a58", hi: "#ffe0c3" },
+      { name: "Saturn", r: 28, base: "#f0d7a5", shade: "#c9a96a", hi: "#fff0d4", ring: true },
