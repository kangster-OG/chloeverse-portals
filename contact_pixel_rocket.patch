+            txt(ctx, "PLUTO!", 160, 18, "#ffffff", 12, "center");
+          } else if (after < DUR.crash + DUR.boom) {
+            const k = (after - DUR.crash) / DUR.boom;
+            drawExplosion(ctx, 200, 92, k);
+            txt(ctx, "BOOM!!", 160, 18, "#ff7da1", 14, "center");
+            if (k > 0.65) setOnce();
+          } else {
+            setOnce();
+          }
+        }
+      }
+
+      if (t > total) setOnce();
+      rafRef.current = requestAnimationFrame(frame);
+    };
+
+    rafRef.current = requestAnimationFrame(frame);
+    return () => {
+      if (rafRef.current != null) cancelAnimationFrame(rafRef.current);
+      rafRef.current = null;
+    };
+  }, [PLANETS, DUR, flyStart, flyTotal, total, W, H]);
+
+  return (
